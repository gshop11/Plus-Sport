# =============================================
# CONFIGURACIÓN DEL PROYECTO
# Copia este archivo como .env y completa los valores
# =============================================

# Base de datos PostgreSQL
DATABASE_URI=postgresql://usuario:contraseña@localhost:5432/nombre_bd

# Clave secreta para Payload CMS (mínimo 32 caracteres, cualquier texto aleatorio)
PAYLOAD_SECRET=cambia-esto-por-una-clave-secreta-larga

# URL pública de la tienda
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Notificaciones WhatsApp al admin (CallMeBot - gratuito)
# Para activar: envía "I allow callmebot to send me messages" al +34 644 81 30 69 por WhatsApp
# Luego recibirás tu APIKEY. Ponla aquí:
CALLMEBOT_APIKEY=
