{
  "name": "plussport-template",
  "version": "1.0.0",
  "description": "Plantilla de tienda deportiva reutilizable con panel admin",
  "scripts": {
    "dev": "next dev",
        "build": "payload migrate && next build",
    "start": "next start",
    "dev:win": "powershell -ExecutionPolicy Bypass -File ./scripts/next-workflow.ps1 dev",
    "build:win": "powershell -ExecutionPolicy Bypass -File ./scripts/next-workflow.ps1 build",
    "start:win": "powershell -ExecutionPolicy Bypass -File ./scripts/next-workflow.ps1 start",
    "reset:win": "powershell -ExecutionPolicy Bypass -File ./scripts/next-workflow.ps1 reset",
    "generate:types": "payload generate:types",
    "seed": "npx tsx src/seed.ts",
    "seed:catalogo": "npx tsx src/seed-catalogo.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@payloadcms/db-postgres": "^3.79.1",
    "@payloadcms/db-sqlite": "^3.79.1",
    "@payloadcms/next": "^3.79.1",
    "@payloadcms/richtext-lexical": "^3.79.1",
    "graphql": "^16.13.1",
    "next": "^15.4.11",
    "payload": "^3.79.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
